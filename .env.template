# App Configuration
APP_NAME="Smart Album API"
DEBUG=true

# Model Configuration
# MODEL_PATH="/path/to/model"
CUDA_DEVICE="0"

# Embedding Service Configuration (API-based)
EMBEDDING_API_PROVIDER="aliyun"
ALIYUN_EMBEDDING_API_KEY="YOUR_ALIYUN_EMBEDDING_API_KEY"
ALIYUN_EMBEDDING_MODEL_NAME="qwen3-vl-embedding"
ALIYUN_EMBEDDING_DIMENSION=2560

# OpenAI / OpenJiuwen Agent Configuration
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
OPENAI_MODEL_NAME="qwen3.5-plus"

# SSL Configuration for OpenJiuwen
LLM_SSL_VERIFY="false"

# Multi-modal Visual Understanding Model Configuration (qwen3-vl-plus)
# Primary Vision Model
VISION_MODEL_NAME="qwen3-vl-plus"
VISION_MODEL_API_KEY="YOUR_VISION_MODEL_API_KEY"
VISION_MODEL_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Image Generation Model Configuration (Reserved)
# IMAGE_GENERATION_MODEL_NAME=""
# IMAGE_GENERATION_MODEL_API_KEY=""
# IMAGE_GENERATION_MODEL_BASE_URL=""

# Image Editing Model Configuration (Reserved)
# IMAGE_EDITING_MODEL_NAME=""
# IMAGE_EDITING_MODEL_API_KEY=""
# IMAGE_EDITING_MODEL_BASE_URL=""

# ASR (Automatic Speech Recognition) Configuration
# ASR_API_KEY="YOUR_ASR_API_KEY"  # If not set, will use OPENAI_API_KEY
ASR_MODEL_NAME="qwen3-asr-flash-realtime"
ASR_BASE_URL="wss://dashscope.aliyuncs.com/api-ws/v1/realtime"
ASR_LANGUAGE="zh"
ASR_SAMPLE_RATE=16000
ASR_INPUT_FORMAT="pcm"
ASR_ENABLE_VAD=true
ASR_VAD_THRESHOLD=0.0
ASR_VAD_SILENCE_MS=400

# Qdrant Configuration
QDRANT_MODE="local"
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# 3DGS Point Cloud Service Configuration
POINTCLOUD_SERVICE_URL="http://localhost:5000"
POINTCLOUD_SERVICE_TIMEOUT=300